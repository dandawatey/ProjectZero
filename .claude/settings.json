{
  "factory": {
    "name": "ProjectZeroFactory",
    "version": "1.0.0",
    "mode": "governed"
  },
  "behavior": {
    "autonomy": "supervised",
    "lowTokenMode": false,
    "truthfulCompletion": true,
    "noTicketNoWork": true,
    "learningEnabled": true
  },
  "governance": {
    "requireMakerChecker": true,
    "requireReview": true,
    "requireApproval": true,
    "requireTests": true,
    "minTestCoverage": 80
  },
  "integrations": {
    "jira": {
      "enabled": false,
      "project": "",
      "url": ""
    },
    "confluence": {
      "enabled": false,
      "space": "",
      "url": ""
    },
    "github": {
      "enabled": true,
      "org": "",
      "repo": ""
    }
  },
  "commands": {
    "entryPoint": "/factory-init",
    "productCreation": "/bootstrap-product"
  },
  "recovery": {
    "checkpointEnabled": true,
    "maxRetries": 3,
    "autoResume": true
  },
  "concurrency": {
    "maxParallelAgents": 3,
    "queueOverflow": "block"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/claude_mem_session_start.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Glob|Grep|Read|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f .claude/graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify-ts: Knowledge graph exists. Read .claude/graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '(graphify-ts generate . --wiki --svg 2>/dev/null && rsync -a --delete graphify-out/ .claude/graphify-out/ 2>/dev/null && rm -rf graphify-out/) &' || true"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/post_tool_use.sh 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post_tool_use.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/claude_mem_stop.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/claude_mem_brain_sync.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/claude_mem_session_end.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/claude_mem_brain_sync.sh 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
