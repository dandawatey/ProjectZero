{
  "factory": {
    "name": "ProjectZeroFactory",
    "version": "1.0.0",
    "mode": "governed"
  },
  "behavior": {
    "autonomy": "supervised",
    "lowTokenMode": false,
    "truthfulCompletion": true,
    "noTicketNoWork": true,
    "learningEnabled": true
  },
  "governance": {
    "requireMakerChecker": true,
    "requireReview": true,
    "requireApproval": true,
    "requireTests": true,
    "minTestCoverage": 80
  },
  "integrations": {
    "jira": {
      "enabled": false,
      "project": "",
      "url": ""
    },
    "confluence": {
      "enabled": false,
      "space": "",
      "url": ""
    },
    "github": {
      "enabled": true,
      "org": "",
      "repo": ""
    }
  },
  "commands": {
    "entryPoint": "/factory-init",
    "productCreation": "/bootstrap-product"
  },
  "recovery": {
    "checkpointEnabled": true,
    "maxRetries": 3,
    "autoResume": true
  },
  "concurrency": {
    "maxParallelAgents": 3,
    "queueOverflow": "block"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f .claude/graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify-ts: Knowledge graph exists. Read .claude/graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      }
    ]
  }
}
