# ── Console backend ─────────────────────────────────────────────────────────
EXECUTION_CONSOLE_URL=http://localhost:8001
CONSOLE_DB_PATH=~/.projectzero/console.db
CONSOLE_LOG_PATH=~/.projectzero/events.jsonl
CONSOLE_REFRESH_SECONDS=2.0

# ── JIRA (for live hierarchy fetch) ──────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=PRJ0

# ── Temporal (for live workflow polling) ─────────────────────────────────────
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_UI_URL=http://localhost:8233

# ── ProjectZero platform backend ─────────────────────────────────────────────
PROJECTZERO_BASE_URL=http://localhost:8000
PROJECTZERO_TOKEN=your-jwt-token

# ── Claude Code hook env vars (set in your shell session) ────────────────────
# Export these before starting a Claude Code session on a ticket.
# The .claude/hooks/post_tool_use.sh hook reads these and emits events.
CLAUDE_CURRENT_TICKET=PRJ0-49
CLAUDE_AGENT_NAME=impl-agent

# ── OpenTelemetry (optional) ─────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=execution-console
