# Execution Console Configuration
EXECUTION_CONSOLE_URL=http://localhost:8001
CONSOLE_DB_PATH=~/.projectzero/console.db

# JIRA (for live hierarchy fetch)
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=you@example.com
JIRA_API_TOKEN=your-token

# Temporal (for live workflow polling)
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# ProjectZero backend (for rich context)
PROJECTZERO_BASE_URL=http://localhost:8000
PROJECTZERO_TOKEN=your-jwt-token

# Claude Code hook env vars (set in shell)
CLAUDE_CURRENT_TICKET=PRJ0-49
CLAUDE_AGENT_NAME=impl-agent
