# =============================================================================
# ProjectZeroFactory Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- JIRA Integration ---
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_API_TOKEN=
JIRA_USER_EMAIL=
JIRA_PROJECT_KEY=PZ
JIRA_BOARD_ID=

# --- Confluence Integration ---
CONFLUENCE_BASE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=PZ

# --- GitHub Integration ---
GITHUB_TOKEN=
GITHUB_ORG=your-org
GITHUB_DEFAULT_BRANCH=main

# --- AI Provider Keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Redis (Queue and Cache) ---
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/projectzero
DATABASE_POOL_SIZE=10

# --- Dagster (Pipeline Orchestration) ---
DAGSTER_HOME=/opt/dagster/home
DAGSTER_HOST=localhost
DAGSTER_PORT=3000

# --- Storybook (UI Development) ---
STORYBOOK_PORT=6006
STORYBOOK_HOST=localhost

# --- FastAPI Workers ---
WORKER_HOST=0.0.0.0
WORKER_PORT=8000
WORKER_CONCURRENCY=4

# --- Logging and Observability ---
LOG_LEVEL=info
SENTRY_DSN=
DATADOG_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Feature Flags ---
ENABLE_LOCAL_FALLBACK=true
ENABLE_MEMORY_PERSISTENCE=true
ENABLE_PIPELINE_MODE=false

# --- Product Configuration (set per product) ---
PRODUCT_NAME=
PRODUCT_REPO_URL=
PRODUCT_CONFLUENCE_HUB_ID=
