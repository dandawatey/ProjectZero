# =============================================================================
# ProjectZeroFactory Environment Configuration
# =============================================================================
# Copy to .env: cp .env.example .env
# Or run guided setup: ./scripts/guided-setup.sh
# NEVER commit .env to version control.
# =============================================================================

# ── REQUIRED: GitHub ─────────────────────────────
# Get token: https://github.com/settings/tokens (scopes: repo, workflow)
GITHUB_TOKEN=
GITHUB_ORG=
GITHUB_DEFAULT_BRANCH=main

# ── REQUIRED: JIRA ───────────────────────────────
# Get token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_BOARD_ID=

# ── REQUIRED: Confluence ─────────────────────────
# Same Atlassian token as JIRA
CONFLUENCE_BASE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=

# ── REQUIRED: Temporal ───────────────────────────
# Start local: temporal server start-dev
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=projectzero-factory

# ── REQUIRED: Database ───────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/projectzero
DATABASE_POOL_SIZE=10

# ── REQUIRED: Redis ──────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── REQUIRED: AI Provider ────────────────────────
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── OPTIONAL: Observability ──────────────────────
SENTRY_DSN=
POSTHOG_API_KEY=
DATADOG_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info

# ── OPTIONAL: Payments ───────────────────────────
STRIPE_SECRET_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── OPTIONAL: Storage ────────────────────────────
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=

# ── Product Config (set per product) ─────────────
PRODUCT_NAME=
PRODUCT_REPO_URL=
PRODUCT_CONFLUENCE_HUB_ID=

# ── Platform Ports ───────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000
STORYBOOK_PORT=6006
DAGSTER_PORT=3001
